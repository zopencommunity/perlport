From f5c469ad87828b03d3109e2a239548b713bb6b43 Mon Sep 17 00:00:00 2001
From: Igor Todorovski <itodorov@ca.ibm.com>
Date: Wed, 14 May 2025 17:07:23 -0600
Subject: [PATCH] makedepend_file.SH: Add some sed edits for z/OS

---
 makedependfile.SH | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/makedependfile.SH b/makedependfile.SH
index 10732f97183e..0f0ed996c0bc 100644
--- a/makedependfile.SH
+++ b/makedependfile.SH
@@ -135,6 +135,11 @@ esac
         $cppstdin -DPERL_CORE $finc -I. $cppflags $cppminus <UU/$file.c |
         $sed \
     	    -e '/^#.*<stdin>/d' \
+          -e '/^#.*<builtin>/d' \
+          -e '/^#.*<built-in>/d' \
+          -e '/^#.*<command line>/d' \
+          -e '/^#.*<command-line>/d' \
+          -e '/".*In file included from.*:/d' \'
 	    -e '/^#.*"-"/d' \
 	    -e '/^#.*git_version\.h/d' \
 	    -e 's#\.[0-9][0-9]*\.c#'"$file.c#" \
